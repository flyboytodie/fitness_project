<view class="container">
  <view class="page-header">
    <text class="page-title">饮食记录</text>
    <button class="btn btn-primary" bindtap="goToAdd">➕ 记录饮食</button>
  </view>

  <view class="calories-card">
    <view class="calories-header">
      <text class="calories-label">今日摄入</text>
      <text class="calories-value">{{todayCalories}} kcal</text>
    </view>
    <view class="nutrition-grid">
      <view class="nutrition-item">
        <text class="nutrition-value">{{todayProtein}}</text>
        <text class="nutrition-label">蛋白质(g)</text>
      </view>
      <view class="nutrition-item">
        <text class="nutrition-value">{{todayCarbs}}</text>
        <text class="nutrition-label">碳水(g)</text>
      </view>
      <view class="nutrition-item">
        <text class="nutrition-value">{{todayFat}}</text>
        <text class="nutrition-label">脂肪(g)</text>
      </view>
    </view>
  </view>

  <view wx:if="{{dietList.length > 0}}" class="card">
    <view class="card-title">饮食记录</view>
    <view wx:for="{{dietList}}" wx:key="id" class="diet-item" bindtap="viewDiet" data-id="{{item.id}}">
      <view class="diet-info">
        <text class="diet-name">{{item.name}}</text>
        <text class="diet-detail">{{item.dateStr}} {{item.time}}</text>
      </view>
      <text class="diet-calories">{{item.calories}}kcal</text>
      <text class="diet-arrow">›</text>
    </view>
  </view>

  <view wx:else class="empty-state">
    <text class="empty-icon">🍎</text>
    <text class="empty-title">暂无饮食记录</text>
    <button class="btn btn-primary" bindtap="goToAdd">记录饮食</button>
  </view>
</view>