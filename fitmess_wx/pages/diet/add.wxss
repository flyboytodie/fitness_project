.container {
  padding: 24rpx;
  padding-bottom: calc(env(safe-area-inset-bottom) + 140rpx);
}

.page-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.back-btn {
  font-size: 32rpx;
  padding: 12rpx;
  color: #2563EB;
}

.page-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #1E293B;
}

.placeholder {
  width: 80rpx;
}

.card {
  background: #fff;
  border-radius: 20rpx;
  padding: 24rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.06);
}

.form-item {
  margin-bottom: 24rpx;
}

.form-item:last-child {
  margin-bottom: 0;
}

.form-label {
  font-size: 26rpx;
  color: #64748B;
  margin-bottom: 12rpx;
  display: block;
}

.form-value {
  padding: 20rpx;
  background: #F8FAFC;
  border-radius: 14rpx;
  font-size: 28rpx;
}

.form-input {
  padding: 20rpx;
  background: #F8FAFC;
  border-radius: 14rpx;
  font-size: 28rpx;
  border: 2rpx solid #E2E8F0;
  width: 100%;
  box-sizing: border-box;
}

.form-input.small {
  width: 100%;
}

.nutrition-row {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 16rpx;
}

.nutrition-input {}

.btn {
  padding: 22rpx;
  border-radius: 14rpx;
  font-size: 28rpx;
  font-weight: 600;
  border: none;
  width: 100%;
}

.btn-primary {
  background: #2563EB;
  color: #fff;
}

.submit-btn {
  margin-top: 24rpx;
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 24rpx 24rpx calc(env(safe-area-inset-bottom) + 24rpx);
  background: #fff;
  box-shadow: 0 -4rpx 12rpx rgba(0, 0, 0, 0.06);
}

.submit-btn .btn {
  width: 100%;
}