.container {
  padding: 24rpx;
  padding-bottom: calc(env(safe-area-inset-bottom) + 140rpx);
}

.card {
  background: #fff;
  border-radius: 20rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.06);
}

.section-title {
  font-size: 26rpx;
  color: #64748B;
  margin-bottom: 16rpx;
  padding-bottom: 16rpx;
  border-bottom: 1rpx solid #E2E8F0;
}

.settings-list {
  display: flex;
  flex-direction: column;
}

.setting-item {
  display: flex;
  align-items: center;
  padding: 24rpx 0;
  border-bottom: 1rpx solid #E2E8F0;
}

.setting-item:last-child {
  border-bottom: none;
}

.setting-item.danger {
  color: #EF4444;
}

.setting-icon {
  font-size: 40rpx;
  margin-right: 20rpx;
}

.setting-label {
  flex: 1;
  font-size: 28rpx;
}

.setting-arrow {
  font-size: 32rpx;
  color: #94A3B8;
}

.goal-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 0;
}

.goal-label {
  font-size: 28rpx;
}

.goal-input-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.goal-input {
  width: 100rpx;
  padding: 12rpx 16rpx;
  border: 2rpx solid #E2E8F0;
  border-radius: 12rpx;
  font-size: 28rpx;
  text-align: center;
}

.goal-unit {
  font-size: 24rpx;
  color: #64748B;
}

.modal-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
  padding: 40rpx;
}

.modal-content {
  background: #fff;
  border-radius: 24rpx;
  width: 100%;
  max-width: 600rpx;
  overflow: hidden;
}

.modal-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 30rpx;
  border-bottom: 1rpx solid #E2E8F0;
}

.modal-title {
  font-size: 32rpx;
  font-weight: 600;
}

.modal-close {
  background: none;
  border: none;
  font-size: 40rpx;
  color: #64748B;
  padding: 8rpx;
}

.modal-body {
  padding: 30rpx;
}

.modal-desc {
  font-size: 26rpx;
  color: #64748B;
  margin-bottom: 20rpx;
  display: block;
}

.import-textarea {
  width: 100%;
  height: 300rpx;
  padding: 20rpx;
  border: 2rpx solid #E2E8F0;
  border-radius: 16rpx;
  font-size: 26rpx;
  box-sizing: border-box;
}

.modal-footer {
  display: flex;
  gap: 20rpx;
  padding: 24rpx 30rpx;
  border-top: 1rpx solid #E2E8F0;
}

.modal-footer .btn {
  flex: 1;
  padding: 20rpx;
  border-radius: 14rpx;
  font-size: 28rpx;
  font-weight: 600;
  border: none;
}

.btn-primary {
  background: #2563EB;
  color: #fff;
}

.btn-secondary {
  background: #F1F5F9;
  color: #2563EB;
  border: 4rpx solid #2563EB;
}