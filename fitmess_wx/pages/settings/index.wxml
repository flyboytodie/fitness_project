<view class="container">
  <view class="card">
    <view class="section-title">数据管理</view>
    <view class="settings-list">
      <view class="setting-item" bindtap="goToAnalysis">
        <text class="setting-icon">📊</text>
        <text class="setting-label">数据分析</text>
        <text class="setting-arrow">›</text>
      </view>
      <view class="setting-item" bindtap="goToExercise">
        <text class="setting-icon">🏋️</text>
        <text class="setting-label">动作库管理</text>
        <text class="setting-arrow">›</text>
      </view>
    </view>
  </view>

  <view class="card">
    <view class="section-title">目标设置</view>
    <view class="goal-item">
      <text class="goal-label">每周训练目标</text>
      <view class="goal-input-row">
        <input type="number" value="{{settings.weeklyGoal}}" bindinput="setWeeklyGoal" class="goal-input" />
        <text class="goal-unit">天/周</text>
      </view>
    </view>
  </view>

  <view class="card">
    <view class="section-title">数据操作</view>
    <view class="settings-list">
      <view class="setting-item" bindtap="exportData">
        <text class="setting-icon">📤</text>
        <text class="setting-label">导出数据</text>
        <text class="setting-arrow">›</text>
      </view>
      <view class="setting-item" bindtap="showImportModal">
        <text class="setting-icon">📥</text>
        <text class="setting-label">导入数据</text>
        <text class="setting-arrow">›</text>
      </view>
      <view class="setting-item danger" bindtap="clearAllData">
        <text class="setting-icon">🗑️</text>
        <text class="setting-label">清除所有数据</text>
        <text class="setting-arrow">›</text>
      </view>
    </view>
  </view>

  <view wx:if="{{showModal}}" class="modal-overlay" bindtap="closeModal">
    <view class="modal-content" catchtap="stopPropagation">
      <view class="modal-header">
        <text class="modal-title">导入数据</text>
        <button class="modal-close" bindtap="closeModal">×</button>
      </view>
      <view class="modal-body">
        <text class="modal-desc">请粘贴导出的JSON数据</text>
        <textarea placeholder="在此粘贴数据..." value="{{importData}}" bindinput="setImportData" class="import-textarea" />
      </view>
      <view class="modal-footer">
        <button class="btn btn-secondary" bindtap="closeModal">取消</button>
        <button class="btn btn-primary" bindtap="importData">导入</button>
      </view>
    </view>
  </view>
</view>