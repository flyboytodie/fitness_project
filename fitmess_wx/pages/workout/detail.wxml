<view class="container">
  <view class="page-header">
    <button class="back-btn" bindtap="goBack">← 返回</button>
    <text class="page-title">训练详情</text>
    <text class="placeholder"></text>
  </view>

  <view wx:if="{{workout}}" class="card">
    <view class="workout-date-card">
      <text class="workout-date">{{workout.dateStr}}</text>
      <text class="workout-parts">{{workout.parts}}</text>
    </view>

    <view class="exercises-section">
      <text class="section-title">训练动作</text>
      <view wx:for="{{workout.exercises}}" wx:key="name" class="exercise-card">
        <text class="exercise-name">{{item.name}}</text>
        <view class="exercise-stats">
          <text class="stat-item">{{item.weight}}kg</text>
          <text class="stat-divider">×</text>
          <text class="stat-item">{{item.sets.join('/')}}</text>
          <text class="stat-total">= {{item.totalReps}}次</text>
        </view>
      </view>
    </view>
  </view>

  <view wx:else class="empty-state">
    <text class="empty-icon">🏋️</text>
    <text class="empty-title">训练记录不存在</text>
    <button class="btn btn-primary" bindtap="goBack">返回</button>
  </view>
</view>