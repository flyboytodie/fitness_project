.container {
  padding: 24rpx;
  padding-bottom: calc(env(safe-area-inset-bottom) + 140rpx);
}

.page-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.page-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #1E293B;
}

.btn {
  padding: 16rpx 28rpx;
  border-radius: 12rpx;
  font-size: 26rpx;
  font-weight: 600;
  border: none;
}

.btn-primary {
  background: #2563EB;
  color: #fff;
}

.workout-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.workout-card {
  background: #fff;
  border-radius: 20rpx;
  padding: 24rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.06);
  position: relative;
}

.workout-card:active {
  background: #F8FAFC;
}

.workout-arrow {
  position: absolute;
  right: 24rpx;
  top: 50%;
  transform: translateY(-50%);
  color: #94A3B8;
  font-size: 36rpx;
}

.workout-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.workout-date {
  font-size: 28rpx;
  font-weight: 600;
  color: #1E293B;
}

.workout-parts {
  font-size: 22rpx;
  padding: 6rpx 14rpx;
  background: #2563EB;
  color: #fff;
  border-radius: 8rpx;
}

.workout-content {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.exercise-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 14rpx 0;
  border-bottom: 1rpx solid #E2E8F0;
}

.exercise-row:last-child {
  border-bottom: none;
}

.exercise-name {
  font-weight: 500;
  font-size: 26rpx;
}

.exercise-detail {
  font-size: 24rpx;
  color: #64748B;
}

.empty-state {
  text-align: center;
  padding: 80rpx 40rpx;
}

.empty-icon {
  font-size: 100rpx;
  margin-bottom: 24rpx;
  display: block;
}

.empty-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #1E293B;
  margin-bottom: 24rpx;
  display: block;
}