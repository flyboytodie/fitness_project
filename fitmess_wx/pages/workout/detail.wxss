.container {
  padding: 24rpx;
  padding-bottom: calc(env(safe-area-inset-bottom) + 140rpx);
}

.page-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.back-btn {
  font-size: 32rpx;
  padding: 12rpx;
  color: #2563EB;
}

.page-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #1E293B;
}

.placeholder {
  width: 80rpx;
}

.card {
  background: #fff;
  border-radius: 20rpx;
  padding: 24rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.06);
}

.workout-date-card {
  background: linear-gradient(135deg, #2563EB 0%, #1D4ED8 100%);
  border-radius: 20rpx;
  padding: 28rpx;
  color: #fff;
  margin-bottom: 24rpx;
}

.workout-date {
  display: block;
  font-size: 32rpx;
  font-weight: 600;
}

.workout-parts {
  display: block;
  font-size: 26rpx;
  opacity: 0.9;
  margin-top: 8rpx;
}

.section-title {
  font-size: 28rpx;
  font-weight: 600;
  margin-bottom: 20rpx;
  display: block;
  color: #1E293B;
}

.exercise-card {
  background: #F8FAFC;
  border-radius: 16rpx;
  padding: 20rpx;
  margin-bottom: 16rpx;
}

.exercise-card:last-child {
  margin-bottom: 0;
}

.exercise-name {
  font-weight: 600;
  font-size: 28rpx;
  display: block;
  margin-bottom: 12rpx;
}

.exercise-stats {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.stat-item {
  font-size: 26rpx;
  color: #64748B;
}

.stat-divider {
  color: #94A3B8;
}

.stat-total {
  margin-left: auto;
  color: #2563EB;
  font-weight: 600;
  font-size: 26rpx;
}

.empty-state {
  text-align: center;
  padding: 80rpx 40rpx;
}

.empty-icon {
  display: block;
  font-size: 100rpx;
  margin-bottom: 24rpx;
}

.empty-title {
  display: block;
  font-size: 28rpx;
  font-weight: 600;
  color: #1E293B;
  margin-bottom: 24rpx;
}

.btn {
  padding: 22rpx 48rpx;
  border-radius: 14rpx;
  font-size: 28rpx;
  font-weight: 600;
  border: none;
}

.btn-primary {
  background: #2563EB;
  color: #fff;
}