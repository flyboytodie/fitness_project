.container {
  padding: 24rpx;
  padding-bottom: calc(env(safe-area-inset-bottom) + 140rpx);
}

.header-card {
  background: linear-gradient(135deg, #2563EB 0%, #1D4ED8 100%);
  border-radius: 28rpx;
  padding: 28rpx;
  margin-bottom: 20rpx;
  color: #fff;
}

.greeting-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.greeting-text {
  font-size: 36rpx;
  font-weight: 700;
}

.date-text {
  font-size: 24rpx;
  opacity: 0.8;
}

.week-progress {
  background: rgba(255, 255, 255, 0.2);
  border-radius: 16rpx;
  padding: 20rpx;
}

.progress-header {
  display: flex;
  justify-content: space-between;
  margin-bottom: 12rpx;
}

.progress-label,
.progress-value {
  font-size: 26rpx;
}

.progress-value {
  font-weight: 600;
}

.progress-bar {
  height: 12rpx;
  background: rgba(255, 255, 255, 0.3);
  border-radius: 8rpx;
  overflow: hidden;
}

.progress-fill {
  height: 100%;
  background: #fff;
  border-radius: 8rpx;
  transition: width 0.3s ease-out;
}

.progress-hint {
  font-size: 22rpx;
  opacity: 0.8;
  margin-top: 8rpx;
  text-align: right;
}

.stats-card {
  background: #fff;
  border-radius: 20rpx;
  padding: 20rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.06);
}

.stats-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 16rpx;
}

.stat-item {
  text-align: center;
  padding: 12rpx;
  border-radius: 12rpx;
}

.stat-item:active {
  background: #F8FAFC;
}

.stat-value {
  display: block;
  font-size: 40rpx;
  font-weight: 700;
  font-family: "SF Mono", monospace;
}

.stat-value.streak {
  color: #F59E0B;
}

.stat-label {
  display: block;
  font-size: 22rpx;
  color: #64748B;
  margin-top: 6rpx;
}

.quick-actions {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 16rpx;
  margin-bottom: 20rpx;
}

.btn {
  padding: 22rpx;
  border-radius: 16rpx;
  font-size: 28rpx;
  font-weight: 600;
  border: none;
}

.btn-primary {
  background: #2563EB;
  color: #fff;
}

.btn-secondary {
  background: #F1F5F9;
  color: #2563EB;
  border: 4rpx solid #2563EB;
}

.card {
  background: #fff;
  border-radius: 20rpx;
  padding: 20rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.06);
}

.card-title {
  font-size: 28rpx;
  font-weight: 600;
  margin-bottom: 16rpx;
  color: #1E293B;
}

.history-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16rpx;
  background: #F8FAFC;
  border-radius: 12rpx;
  margin-bottom: 12rpx;
}

.history-item:last-child {
  margin-bottom: 0;
}

.history-date {
  font-weight: 600;
  font-size: 26rpx;
}

.history-parts {
  font-size: 24rpx;
  color: #64748B;
}

.history-sets {
  font-size: 24rpx;
  color: #2563EB;
}