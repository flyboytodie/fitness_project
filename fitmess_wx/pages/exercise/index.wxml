<view class="container">
  <view class="page-header">
    <button class="back-btn" bindtap="goBack">← 返回</button>
    <text class="page-title">动作库</text>
    <button class="add-btn" bindtap="openAddModal">➕ 添加</button>
  </view>

  <view class="filter-tabs">
    <view wx:for="{{parts}}" wx:key="*this" class="filter-tab {{selectedPart === item ? 'active' : ''}}" bindtap="filterByPart" data-part="{{item}}">
      {{item}}
    </view>
  </view>

  <view class="exercise-list">
    <view wx:for="{{filteredExercises}}" wx:key="name" class="exercise-item">
      <view class="exercise-info">
        <text class="exercise-name">{{item.name}}</text>
        <text class="exercise-muscle">{{item.muscle}} · {{item.equipment}}</text>
      </view>
      <view class="exercise-actions">
        <button class="action-btn edit" bindtap="openEditModal" data-name="{{item.name}}">编辑</button>
        <button class="action-btn delete" bindtap="deleteExercise" data-name="{{item.name}}">删除</button>
      </view>
    </view>
  </view>

  <view wx:if="{{filteredExercises.length === 0}}" class="empty-state">
    <text class="empty-icon">🏋️</text>
    <text class="empty-title">暂无动作</text>
    <button class="btn btn-primary" bindtap="openAddModal">添加动作</button>
  </view>

  <view wx:if="{{showModal}}" class="modal-overlay" bindtap="closeModal">
    <view class="modal-content" catchtap="stopPropagation">
      <view class="modal-header">
        <text class="modal-title">{{editingExercise ? '编辑动作' : '添加动作'}}</text>
        <button class="modal-close" bindtap="closeModal">×</button>
      </view>
      <view class="modal-body">
        <view class="form-item">
          <text class="form-label">动作名称</text>
          <input placeholder="例如：杠铃卧推" value="{{formData.name}}" bindinput="setFormData" data-field="name" class="form-input" />
        </view>
        <view class="form-item">
          <text class="form-label">训练部位</text>
          <picker mode="selector" range="{{parts.slice(1)}}" bindchange="setFormData" data-field="muscle">
            <view class="form-value">{{formData.muscle || '选择部位'}}</view>
          </picker>
        </view>
        <view class="form-item">
          <text class="form-label">使用器械</text>
          <input placeholder="例如：杠铃" value="{{formData.equipment}}" bindinput="setFormData" data-field="equipment" class="form-input" />
        </view>
      </view>
      <view class="modal-footer">
        <button class="btn btn-secondary" bindtap="closeModal">取消</button>
        <button class="btn btn-primary" bindtap="saveExercise">保存</button>
      </view>
    </view>
  </view>
</view>