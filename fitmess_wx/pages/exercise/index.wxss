.container {
  padding: 24rpx;
  padding-bottom: calc(env(safe-area-inset-bottom) + 140rpx);
}

.page-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.back-btn {
  font-size: 32rpx;
  padding: 12rpx;
  color: #2563EB;
}

.page-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #1E293B;
}

.add-btn {
  padding: 12rpx 24rpx;
  background: #2563EB;
  color: #fff;
  border-radius: 12rpx;
  font-size: 26rpx;
  font-weight: 600;
  border: none;
}

.filter-tabs {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-bottom: 24rpx;
}

.filter-tab {
  padding: 12rpx 24rpx;
  background: #F1F5F9;
  border-radius: 32rpx;
  font-size: 26rpx;
  color: #64748B;
}

.filter-tab.active {
  background: #2563EB;
  color: #fff;
}

.exercise-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.exercise-item {
  background: #fff;
  border-radius: 16rpx;
  padding: 20rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.06);
}

.exercise-info {
  margin-bottom: 16rpx;
}

.exercise-name {
  font-size: 28rpx;
  font-weight: 600;
  display: block;
  margin-bottom: 8rpx;
}

.exercise-muscle {
  font-size: 24rpx;
  color: #64748B;
}

.exercise-actions {
  display: flex;
  gap: 16rpx;
}

.action-btn {
  flex: 1;
  padding: 16rpx;
  border-radius: 12rpx;
  font-size: 26rpx;
  font-weight: 500;
  border: none;
}

.action-btn.edit {
  background: #FEF3C7;
  color: #D97706;
}

.action-btn.delete {
  background: #FEE2E2;
  color: #DC2626;
}

.empty-state {
  text-align: center;
  padding: 80rpx 40rpx;
}

.empty-icon {
  font-size: 100rpx;
  margin-bottom: 24rpx;
  display: block;
}

.empty-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #1E293B;
  margin-bottom: 24rpx;
  display: block;
}

.btn {
  padding: 20rpx 40rpx;
  border-radius: 14rpx;
  font-size: 28rpx;
  font-weight: 600;
  border: none;
}

.btn-primary {
  background: #2563EB;
  color: #fff;
}

.btn-secondary {
  background: #F1F5F9;
  color: #2563EB;
  border: 4rpx solid #2563EB;
}

.modal-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: flex-end;
  justify-content: center;
  z-index: 1000;
}

.modal-content {
  background: #fff;
  border-radius: 32rpx 32rpx 0 0;
  width: 100%;
  max-height: 80vh;
  overflow-y: auto;
}

.modal-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 28rpx 32rpx;
  border-bottom: 1rpx solid #E2E8F0;
}

.modal-title {
  font-size: 32rpx;
  font-weight: 600;
}

.modal-close {
  background: none;
  border: none;
  font-size: 40rpx;
  color: #64748B;
  padding: 8rpx;
}

.modal-body {
  padding: 32rpx;
}

.form-item {
  margin-bottom: 24rpx;
}

.form-label {
  font-size: 26rpx;
  color: #64748B;
  margin-bottom: 12rpx;
  display: block;
}

.form-input {
  width: 100%;
  padding: 20rpx;
  border: 2rpx solid #E2E8F0;
  border-radius: 14rpx;
  font-size: 28rpx;
  box-sizing: border-box;
}

.form-value {
  padding: 20rpx;
  border: 2rpx solid #E2E8F0;
  border-radius: 14rpx;
  font-size: 28rpx;
  color: #1E293B;
}

.modal-footer {
  display: flex;
  gap: 20rpx;
  padding: 24rpx 32rpx;
  border-top: 1rpx solid #E2E8F0;
  padding-bottom: calc(env(safe-area-inset-bottom) + 24rpx);
}

.modal-footer .btn {
  flex: 1;
  padding: 22rpx;
}