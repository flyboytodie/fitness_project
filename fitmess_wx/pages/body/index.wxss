.container {
  padding: 24rpx;
  padding-bottom: calc(env(safe-area-inset-bottom) + 140rpx);
}

.page-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.page-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #1E293B;
}

.btn {
  padding: 16rpx 28rpx;
  border-radius: 12rpx;
  font-size: 26rpx;
  font-weight: 600;
  border: none;
}

.btn-primary {
  background: #2563EB;
  color: #fff;
}

.body-card {
  background: #fff;
  border-radius: 24rpx;
  padding: 32rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.06);
}

.weight-section {
  text-align: center;
  margin-bottom: 16rpx;
}

.weight-value {
  font-size: 88rpx;
  font-weight: 700;
  color: #2563EB;
  line-height: 1;
}

.weight-unit {
  font-size: 32rpx;
  color: #64748B;
  margin-left: 8rpx;
}

.record-date {
  font-size: 26rpx;
  color: #64748B;
  text-align: center;
  display: block;
  margin-bottom: 24rpx;
}

.stats-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 16rpx;
}

.stat-card {
  background: #F8FAFC;
  border-radius: 16rpx;
  padding: 20rpx;
  text-align: center;
}

.stat-label {
  font-size: 24rpx;
  color: #64748B;
  margin-bottom: 8rpx;
  display: block;
}

.stat-value {
  font-size: 36rpx;
  font-weight: 700;
  display: block;
}

.stat-status {
  font-size: 22rpx;
  margin-top: 4rpx;
  display: block;
}

.stat-unit {
  font-size: 20rpx;
  color: #64748B;
}

.empty-body-card {
  background: #fff;
  border-radius: 24rpx;
  padding: 60rpx 40rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.06);
  text-align: center;
}

.empty-icon {
  font-size: 100rpx;
  margin-bottom: 24rpx;
  display: block;
}

.empty-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #1E293B;
  margin-bottom: 24rpx;
  display: block;
}

.card {
  background: #fff;
  border-radius: 20rpx;
  padding: 24rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.06);
}

.card-title {
  font-size: 28rpx;
  font-weight: 600;
  margin-bottom: 16rpx;
  color: #1E293B;
}

.record-list {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.record-item {
  display: flex;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #E2E8F0;
}

.record-item:last-child {
  border-bottom: none;
}

.record-date {
  font-size: 26rpx;
  flex: 1;
}

.record-weight {
  font-size: 28rpx;
  font-weight: 600;
  margin-right: 16rpx;
}

.record-bmi {
  font-size: 24rpx;
  color: #64748B;
  margin-right: 16rpx;
}

.record-arrow {
  font-size: 32rpx;
  color: #94A3B8;
}