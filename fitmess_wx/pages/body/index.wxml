<view class="container">
  <view class="page-header">
    <text class="page-title">身体数据</text>
    <button class="btn btn-primary" bindtap="goToAdd">➕ 添加记录</button>
  </view>

  <view wx:if="{{latestRecord}}" class="body-card">
    <view class="weight-section">
      <text class="weight-value">{{latestRecord.weight}}</text>
      <text class="weight-unit">kg</text>
    </view>
    <text class="record-date">{{latestRecord.date}}</text>

    <view class="stats-grid">
      <view class="stat-card">
        <text class="stat-label">BMI</text>
        <text class="stat-value" style="color: {{latestRecord.bmiColor}}">{{latestRecord.bmi}}</text>
        <text class="stat-status" style="color: {{latestRecord.bmiColor}}">{{latestRecord.bmiText}}</text>
      </view>
      <view class="stat-card">
        <text class="stat-label">体脂率</text>
        <text class="stat-value">{{latestRecord.bodyFat}}%</text>
      </view>
      <view class="stat-card">
        <text class="stat-label">肌肉量</text>
        <text class="stat-value">{{latestRecord.muscle}}kg</text>
      </view>
      <view class="stat-card">
        <text class="stat-label">基础代谢</text>
        <text class="stat-value">{{latestRecord.bmr}}</text>
        <text class="stat-unit">kcal</text>
      </view>
    </view>
  </view>

  <view wx:else class="empty-body-card">
    <text class="empty-icon">⚖️</text>
    <text class="empty-title">暂无身体数据</text>
    <button class="btn btn-primary" bindtap="goToAdd">添加记录</button>
  </view>

  <view wx:if="{{records.length > 0}}" class="card">
    <view class="card-title">历史记录</view>
    <view wx:for="{{records}}" wx:key="id" class="record-item" bindtap="viewRecord" data-id="{{item.id}}">
      <text class="record-date">{{item.date}}</text>
      <text class="record-weight">{{item.weight}}kg</text>
      <text class="record-bmi">BMI {{item.bmi}}</text>
      <text class="record-arrow">›</text>
    </view>
  </view>
</view>