<view class="container">
  <view class="page-header">
    <button class="back-btn" bindtap="goBack">← 返回</button>
    <text class="page-title">添加身体数据</text>
    <text class="placeholder"></text>
  </view>

  <view class="card">
    <view class="form-item">
      <text class="form-label">日期</text>
      <picker mode="date" value="{{date}}" bindchange="selectDate">
        <view class="form-value">{{date}}</view>
      </picker>
    </view>

    <view class="form-item">
      <text class="form-label">体重(kg)</text>
      <input type="number" placeholder="0" value="{{weight}}" bindinput="setWeight" class="form-input" />
    </view>

    <view class="form-item">
      <text class="form-label">身高(cm)</text>
      <input type="number" placeholder="0" value="{{height}}" bindinput="setHeight" class="form-input" />
    </view>

    <view class="form-row">
      <view class="form-item half">
        <text class="form-label">体脂率(%)</text>
        <input type="number" placeholder="可选" value="{{bodyFat}}" bindinput="setBodyFat" class="form-input" />
      </view>
      <view class="form-item half">
        <text class="form-label">肌肉量(kg)</text>
        <input type="number" placeholder="可选" value="{{muscle}}" bindinput="setMuscle" class="form-input" />
      </view>
    </view>
  </view>

  <button class="btn btn-primary submit-btn" bindtap="saveBody">保存记录</button>
</view>