:root {
  --primary: #2563EB;
  --secondary: #10B981;
  --accent: #F59E0B;
  --danger: #EF4444;
  --bg: #F8FAFC;
  --surface: #FFFFFF;
  --text: #1E293B;
  --text-muted: #64748B;
  --border: #E2E8F0;
}

page {
  background-color: var(--bg);
  font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
  color: var(--text);
  min-height: 100vh;
}

.container {
  padding: 16rpx;
  padding-bottom: calc(env(safe-area-inset-bottom) + 120rpx);
}

.page-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
  padding: 0 8rpx;
}

.page-title {
  font-size: 36rpx;
  font-weight: 700;
  color: var(--text);
}

.card {
  background: var(--surface);
  border-radius: 24rpx;
  padding: 24rpx;
  margin-bottom: 16rpx;
  box-shadow: 0 2rpx 6rpx rgba(0, 0, 0, 0.06);
}

.card-title {
  font-size: 26rpx;
  color: var(--text-muted);
  margin-bottom: 12rpx;
}

.card-title-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
  font-size: 28rpx;
  font-weight: 600;
  color: var(--text);
}

.btn {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  padding: 20rpx 32rpx;
  border-radius: 16rpx;
  border: none;
  font-size: 28rpx;
  font-weight: 600;
}

.btn-primary {
  background: var(--primary);
  color: #fff;
}

.btn-secondary {
  background: var(--surface);
  color: var(--primary);
  border: 4rpx solid var(--primary);
}

.btn-sm {
  padding: 12rpx 24rpx;
  font-size: 24rpx;
}

.btn-danger {
  background: var(--danger);
  color: #fff;
}

.input-group {
  margin-bottom: 20rpx;
}

.input-group label {
  display: block;
  font-size: 24rpx;
  color: var(--text-muted);
  margin-bottom: 8rpx;
}

.input-group input,
.input-group select {
  width: 100%;
  padding: 16rpx 20rpx;
  border: 2rpx solid var(--border);
  border-radius: 12rpx;
  font-size: 28rpx;
  background: #fff;
  box-sizing: border-box;
}

.progress-bar {
  height: 12rpx;
  background: var(--border);
  border-radius: 8rpx;
  overflow: hidden;
  margin-top: 12rpx;
}

.progress-fill {
  height: 100%;
  background: linear-gradient(90deg, var(--primary), var(--secondary));
  border-radius: 8rpx;
  transition: width 0.3s ease-out;
}

.mini-progress-bar {
  height: 8rpx;
  background: var(--border);
  border-radius: 4rpx;
  overflow: hidden;
  margin-top: 8rpx;
}

.mini-progress-fill {
  height: 100%;
  background: linear-gradient(90deg, var(--primary), var(--secondary));
  border-radius: 4rpx;
  transition: width 0.3s ease-out;
}

.mini-progress-text {
  font-size: 22rpx;
  color: var(--text-muted);
  margin-top: 6rpx;
  text-align: right;
}

.tag-group {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.tag {
  padding: 12rpx 24rpx;
  border-radius: 32rpx;
  background: var(--bg);
  border: 2rpx solid var(--border);
  font-size: 24rpx;
}

.tag.active {
  background: var(--primary);
  color: #fff;
  border-color: var(--primary);
}

.tag-filter {
  padding: 10rpx 20rpx;
  font-size: 22rpx;
}

.empty-state {
  text-align: center;
  padding: 60rpx 30rpx;
  color: var(--text-muted);
}

.empty-icon {
  font-size: 100rpx;
  margin-bottom: 24rpx;
  display: block;
}

.empty-title {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--text);
  margin-bottom: 24rpx;
  display: block;
}

.modal-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  z-index: 1000;
  display: flex;
  align-items: flex-end;
  justify-content: center;
}

.modal {
  background: var(--surface);
  border-radius: 32rpx 32rpx 0 0;
  width: 100%;
  max-height: 90vh;
  overflow-y: auto;
  padding: 30rpx;
  animation: slideUp 0.3s ease-out;
}

@keyframes slideUp {
  from { transform: translateY(100%); }
  to { transform: translateY(0); }
}

.modal-header {
  font-size: 32rpx;
  font-weight: 600;
  margin-bottom: 24rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.modal-close {
  background: none;
  border: none;
  font-size: 40rpx;
  color: var(--text-muted);
  padding: 8rpx;
}

.grid-2 { display: grid; grid-template-columns: 1fr 1fr; gap: 16rpx; }
.grid-3 { display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 16rpx; }
.grid-4 { display: grid; grid-template-columns: repeat(4, 1fr); gap: 16rpx; }

.text-muted { color: var(--text-muted); }
.text-primary { color: var(--primary); }
.text-secondary { color: var(--secondary); }
.text-danger { color: var(--danger); }

.back-btn {
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border: none;
  background: transparent;
  font-size: 32rpx;
  border-radius: 12rpx;
}

.back-btn:active {
  background: var(--bg);
}

.save-btn {
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border: none;
  background: transparent;
  font-size: 32rpx;
  color: var(--primary);
  font-weight: 600;
  border-radius: 12rpx;
}

.save-btn:active {
  background: var(--bg);
}

.edit-header {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  background: var(--surface);
  border-bottom: 1rpx solid var(--border);
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 16rpx 24rpx;
  z-index: 100;
}

.edit-title {
  font-size: 30rpx;
  font-weight: 600;
}

.fixed-bottom {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: var(--surface);
  border-top: 1rpx solid var(--border);
  padding: 16rpx 24rpx;
  box-shadow: 0 -4rpx 20rpx rgba(0, 0, 0, 0.05);
  padding-bottom: calc(env(safe-area-inset-bottom) + 16rpx);
}

.toggle-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 0;
  border-bottom: 1rpx solid var(--border);
}

.toggle-item:last-child {
  border-bottom: none;
}

.toggle-label {
  flex: 1;
}

.toggle-label > view:first-child {
  font-weight: 500;
  font-size: 28rpx;
}

.toggle-desc {
  font-size: 22rpx;
  color: var(--text-muted);
  margin-top: 4rpx;
}

.toggle-switch {
  width: 88rpx;
  height: 48rpx;
  background: var(--border);
  border-radius: 24rpx;
  position: relative;
  transition: background 0.3s;
  margin-left: 24rpx;
}

.toggle-switch.active {
  background: var(--primary);
}

.toggle-knob {
  width: 40rpx;
  height: 40rpx;
  background: #fff;
  border-radius: 20rpx;
  position: absolute;
  top: 4rpx;
  left: 4rpx;
  transition: transform 0.3s;
  box-shadow: 0 4rpx 8rpx rgba(0, 0, 0, 0.15);
}

.toggle-switch.active .toggle-knob {
  transform: translateX(40rpx);
}

.search-bar {
  display: flex;
  align-items: center;
  background: #F1F5F9;
  border-radius: 20rpx;
  padding: 14rpx 20rpx;
  margin-bottom: 20rpx;
}

.search-bar input {
  flex: 1;
  background: transparent;
  border: none;
  outline: none;
  font-size: 26rpx;
  color: var(--text);
}

.search-bar input::placeholder {
  color: #94A3B8;
}

.category-filter {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-bottom: 24rpx;
}

.filter-btn {
  padding: 10rpx 20rpx;
  background: #F1F5F9;
  border: 2rpx solid #E2E8F0;
  border-radius: 32rpx;
  font-size: 24rpx;
  color: var(--text-muted);
}

.filter-btn.active {
  background: var(--primary);
  border-color: var(--primary);
  color: #fff;
}

.history-item {
  display: flex;
  justify-content: space-between;
  padding: 20rpx;
  background: var(--bg);
  border-radius: 16rpx;
  margin-bottom: 12rpx;
}

.history-item:active {
  background: var(--border);
}

.history-date {
  font-weight: 600;
  font-size: 26rpx;
}

.history-parts {
  font-size: 24rpx;
  color: var(--text-muted);
}

.history-sets {
  font-size: 24rpx;
  color: var(--primary);
}

.progress-badge {
  display: inline-block;
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
  font-size: 20rpx;
  font-weight: 600;
  margin-left: 12rpx;
}

.progress-badge.new {
  background: var(--secondary);
  color: #fff;
}

.progress-badge.improved {
  background: var(--primary);
  color: #fff;
}

.progress-badge.star {
  background: var(--accent);
  color: #fff;
}

.input-with-unit {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.input-with-unit input {
  flex: 1;
}

.input-unit {
  color: var(--text-muted);
  font-size: 24rpx;
  white-space: nowrap;
}

.star-btn {
  background: none;
  border: none;
  font-size: 32rpx;
  padding: 8rpx;
}

.star-btn.starred {
  color: var(--accent);
}

.action-bar {
  display: flex;
  gap: 12rpx;
  margin-top: 20rpx;
  padding-top: 20rpx;
  border-top: 1rpx solid var(--border);
}

.confirm-modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  z-index: 400;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 40rpx;
}

.confirm-box {
  background: var(--surface);
  border-radius: 28rpx;
  padding: 40rpx;
  max-width: 560rpx;
  width: 100%;
  text-align: center;
}

.confirm-icon {
  font-size: 80rpx;
  margin-bottom: 24rpx;
}

.confirm-title {
  font-size: 32rpx;
  font-weight: 600;
  margin-bottom: 12rpx;
}

.confirm-message {
  font-size: 26rpx;
  color: var(--text-muted);
  margin-bottom: 30rpx;
}

.confirm-buttons {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 20rpx;
}

.toast-container {
  position: fixed;
  top: 120rpx;
  left: 0;
  right: 0;
  z-index: 1000;
  padding: 0 24rpx;
}

.toast {
  background: var(--text);
  color: #fff;
  padding: 20rpx 24rpx;
  border-radius: 16rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.3);
}

.toast-message {
  flex: 1;
  font-size: 26rpx;
}

.toast-btn {
  background: var(--primary);
  color: #fff;
  border: none;
  padding: 12rpx 24rpx;
  border-radius: 10rpx;
  font-size: 24rpx;
  font-weight: 600;
  margin-left: 20rpx;
}

.workout-card {
  position: relative;
}

.workout-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 20rpx;
}

.workout-date {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--text);
}

.workout-parts {
  font-size: 22rpx;
  padding: 6rpx 14rpx;
  background: var(--primary);
  color: #fff;
  border-radius: 8rpx;
}

.workout-pr-badge {
  position: absolute;
  top: -12rpx;
  right: -12rpx;
  background: linear-gradient(135deg, #F59E0B 0%, #D97706 100%);
  color: #fff;
  padding: 6rpx 16rpx;
  border-radius: 16rpx;
  font-size: 20rpx;
  font-weight: 600;
  box-shadow: 0 4rpx 16rpx rgba(245, 158, 11, 0.3);
}

.exercise-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 14rpx 0;
  border-bottom: 1rpx solid var(--border);
  gap: 12rpx;
}

.exercise-row:last-child {
  border-bottom: none;
}

.exercise-name {
  flex: 1;
  font-size: 26rpx;
  font-weight: 500;
}

.exercise-weight {
  font-size: 24rpx;
  font-weight: 600;
  color: var(--primary);
  min-width: 80rpx;
  text-align: right;
}

.exercise-reps {
  font-size: 22rpx;
  color: var(--text-muted);
  min-width: 100rpx;
  text-align: right;
}

.progress-detail {
  background: #F8FAFC;
  padding: 20rpx;
  margin: 12rpx 0 20rpx 0;
  border-radius: 0 12rpx 12rpx 0;
}

.progress-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12rpx;
  font-size: 24rpx;
}

.progress-compare {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.compare-item {
  display: flex;
  align-items: center;
  gap: 12rpx;
  font-size: 24rpx;
  flex-wrap: wrap;
}

.compare-item.previous {
  opacity: 0.6;
  font-size: 22rpx;
}

.compare-label {
  color: var(--text-muted);
  min-width: 140rpx;
}

.compare-value {
  font-weight: 600;
  color: var(--primary);
  min-width: 80rpx;
}

.compare-sets {
  flex: 1;
  font-weight: 500;
  color: var(--text);
  font-family: 'Courier New', monospace;
  background: #E2E8F0;
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
}

.compare-item.previous .compare-sets {
  background: #CBD5E1;
}

.compare-volume {
  font-size: 20rpx;
  color: var(--text-muted);
  min-width: 80rpx;
  text-align: right;
}

.compare-arrow {
  text-align: center;
  color: var(--text-muted);
  font-size: 22rpx;
  padding: 8rpx 0;
}

.quick-fill {
  display: flex;
  gap: 8rpx;
  flex-wrap: wrap;
  margin-top: 12rpx;
}

.quick-fill button {
  padding: 8rpx 16rpx;
  border: 2rpx solid var(--border);
  border-radius: 8rpx;
  background: var(--bg);
  font-size: 22rpx;
}

.quick-fill button:active {
  background: var(--primary);
  color: #fff;
  border-color: var(--primary);
}

.exercise-card {
  background: #fff;
  border: 2rpx solid var(--border);
  border-radius: 20rpx;
  padding: 20rpx;
}

.exercise-info {
  font-size: 24rpx;
  color: var(--text-muted);
  margin-bottom: 20rpx;
}

.exercise-actions {
  display: flex;
  gap: 12rpx;
}

.action-btn {
  flex: 1;
  padding: 14rpx;
  border: none;
  border-radius: 12rpx;
  font-size: 26rpx;
}

.action-btn.edit {
  background: #FEF3C7;
  color: #D97706;
}

.action-btn.delete {
  background: #FEE2E2;
  color: #DC2626;
}

.exercise-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 16rpx;
}

.exercise-grid-item {
  background: #fff;
  border: 4rpx solid var(--border);
  border-radius: 16rpx;
  padding: 16rpx;
}

.exercise-grid-item:active {
  transform: scale(0.98);
}

.exercise-grid-name {
  font-weight: 600;
  font-size: 26rpx;
  color: var(--text);
  margin-bottom: 8rpx;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.exercise-grid-muscle {
  display: inline-block;
  padding: 4rpx 10rpx;
  border-radius: 8rpx;
  font-size: 18rpx;
  font-weight: 500;
}

.muscle-tag {
  padding: 6rpx 14rpx;
  border-radius: 10rpx;
  font-size: 20rpx;
  font-weight: 500;
}

.detail-muscle-tag {
  display: inline-block;
  padding: 10rpx 20rpx;
  border-radius: 32rpx;
  font-size: 24rpx;
  font-weight: 600;
}

.detail-info {
  background: #F8FAFC;
  border-radius: 16rpx;
  padding: 20rpx;
}

.detail-row {
  display: flex;
  justify-content: space-between;
  padding: 14rpx 0;
  border-bottom: 1rpx solid var(--border);
}

.detail-row:last-child {
  border-bottom: none;
}

.detail-label {
  font-size: 24rpx;
  color: var(--text-muted);
}

.detail-value {
  font-size: 24rpx;
  font-weight: 600;
  color: var(--text);
}

.exercise-tag {
  padding: 14rpx 20rpx;
  background: var(--bg);
  border: 2rpx solid var(--border);
  border-radius: 14rpx;
  font-size: 26rpx;
  text-align: center;
}

.exercise-tag:active {
  background: var(--primary);
  color: #fff;
  border-color: var(--primary);
}

.exercise-tag.starred {
  background: #FEF3C7;
  border-color: var(--accent);
}

.exercise-tag.selected {
  background: var(--primary);
  color: #fff;
  border-color: var(--primary);
}

.body-status-card {
  padding: 32rpx;
}

.body-status-main {
  display: flex;
  justify-content: space-around;
  align-items: center;
  margin-bottom: 32rpx;
  padding-bottom: 32rpx;
  border-bottom: 1rpx solid var(--border);
}

.weight-display {
  text-align: center;
}

.weight-value {
  font-size: 80rpx;
  font-weight: 700;
  color: var(--primary);
  line-height: 1;
}

.weight-unit {
  font-size: 28rpx;
  color: var(--text-muted);
  margin-top: 8rpx;
}

.weight-change {
  font-size: 26rpx;
  font-weight: 600;
  margin-top: 12rpx;
}

.weight-change.positive {
  color: var(--danger);
}

.weight-change.negative {
  color: var(--secondary);
}

.bmi-display {
  text-align: center;
}

.bmi-circle {
  width: 140rpx;
  height: 140rpx;
  border-radius: 50%;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  color: #fff;
}

.bmi-circle.normal {
  background: linear-gradient(135deg, var(--secondary), #059669);
}

.bmi-circle.underweight {
  background: linear-gradient(135deg, #3B82F6, #1D4ED8);
}

.bmi-circle.overweight {
  background: linear-gradient(135deg, #F59E0B, #D97706);
}

.bmi-circle.obese {
  background: linear-gradient(135deg, var(--danger), #DC2626);
}

.bmi-value {
  font-size: 40rpx;
  font-weight: 700;
}

.bmi-label {
  font-size: 18rpx;
  opacity: 0.9;
}

.bmi-category {
  font-size: 24rpx;
  color: var(--text-muted);
  margin-top: 12rpx;
  font-weight: 500;
}

.body-stats-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 16rpx;
}

.stat-card {
  display: flex;
  align-items: center;
  gap: 16rpx;
  background: var(--bg);
  padding: 20rpx;
  border-radius: 16rpx;
}

.stat-icon {
  font-size: 40rpx;
  width: 70rpx;
  height: 70rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #fff;
  border-radius: 16rpx;
}

.stat-info {
  flex: 1;
}

.stat-info .stat-value {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--text);
}

.stat-info .stat-label {
  font-size: 22rpx;
  color: var(--text-muted);
}

.stat-unit {
  font-size: 20rpx;
  color: var(--text-muted);
}

.calories-card {
  background: linear-gradient(135deg, #10B981 0%, #059669 100%);
  border-radius: 24rpx;
  padding: 28rpx;
  margin-bottom: 20rpx;
  color: #fff;
}

.calories-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: 24rpx;
}

.calories-label {
  font-size: 26rpx;
  opacity: 0.9;
}

.calories-value {
  font-size: 48rpx;
  font-weight: 700;
}

.nutrition-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 16rpx;
}

.nutrition-item {
  text-align: center;
  background: rgba(255, 255, 255, 0.2);
  border-radius: 16rpx;
  padding: 16rpx;
}

.nutrition-value {
  font-size: 32rpx;
  font-weight: 700;
  display: block;
}

.nutrition-label {
  font-size: 20rpx;
  opacity: 0.8;
  margin-top: 4rpx;
  display: block;
}

.diet-item {
  display: flex;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 1rpx solid var(--border);
}

.diet-item:last-child {
  border-bottom: none;
}

.diet-info {
  flex: 1;
}

.diet-name {
  font-size: 28rpx;
  font-weight: 500;
  display: block;
}

.diet-detail {
  font-size: 24rpx;
  color: var(--text-muted);
  margin-top: 4rpx;
  display: block;
}

.diet-calories {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--primary);
  margin-right: 16rpx;
}

.diet-arrow {
  font-size: 32rpx;
  color: #94A3B8;
}

.record-item {
  display: flex;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 1rpx solid var(--border);
}

.record-item:last-child {
  border-bottom: none;
}

.record-date {
  font-size: 26rpx;
  flex: 1;
}

.record-weight {
  font-size: 28rpx;
  font-weight: 600;
  margin-right: 16rpx;
}

.record-bmi {
  font-size: 24rpx;
  color: var(--text-muted);
  margin-right: 16rpx;
}

.record-arrow {
  font-size: 32rpx;
  color: #94A3B8;
}

.pr-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx;
  background: var(--bg);
  border-radius: 16rpx;
  margin-bottom: 12rpx;
}

.pr-name {
  font-weight: 600;
  font-size: 26rpx;
}

.pr-info {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  gap: 4rpx;
}

.pr-value {
  font-weight: 600;
  color: #F59E0B;
  font-size: 26rpx;
}

.pr-date {
  font-size: 22rpx;
  color: var(--text-muted);
}

.template-card {
  background: var(--bg);
  border-radius: 20rpx;
  padding: 24rpx;
  margin-bottom: 16rpx;
  border: 4rpx solid transparent;
}

.template-card:active {
  transform: scale(0.98);
}

.template-card.selected {
  border-color: var(--primary);
  background: rgba(37, 99, 235, 0.05);
}

.template-name {
  font-weight: 600;
  font-size: 28rpx;
  margin-bottom: 8rpx;
}

.template-desc {
  font-size: 24rpx;
  color: var(--text-muted);
}

.template-actions {
  font-size: 24rpx;
  color: var(--primary);
  margin-top: 12rpx;
}

.pagination {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 24rpx;
  margin-top: 30rpx;
  padding: 24rpx;
}

.pagination-btn {
  padding: 16rpx 32rpx;
  border-radius: 12rpx;
  font-size: 26rpx;
  font-weight: 500;
  background: var(--surface);
  border: 2rpx solid var(--border);
}

.pagination-btn:active:not(.disabled) {
  background: var(--primary);
  color: #fff;
  border-color: var(--primary);
}

.pagination-btn.disabled {
  opacity: 0.5;
}

.pagination-info {
  font-size: 26rpx;
  color: var(--text-muted);
  min-width: 120rpx;
  text-align: center;
}

@media (max-width: 380px) {
  .grid-3 {
    grid-template-columns: 1fr 1fr;
  }
}